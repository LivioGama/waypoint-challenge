{
  "name": "waypoint-iep-mcp",
  "version": "0.1.0",
  "description": "MCP server that helps teachers differentiate instruction using a student's IEP and a lesson",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "mcp": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "demo": "tsx src/demo.ts",
    "parent-summary": "tsx src/parent-summary.ts",
    "parse-iep": "tsx src/parse-iep.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/server.ts",
    "web": "tsx src/bridge.ts",
    "eval": "tsx src/eval.ts",
    "baseline-eval": "tsx src/baseline-eval.ts",
    "ab-compare": "tsx src/ab-compare.ts",
    "verify": "tsx src/verify-citations.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@slack/types": "^2.21.1",
    "@slack/webhook": "^7.0.9",
    "@types/pdf-parse": "^1.1.5",
    "dotenv": "^17.4.2",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.9.0",
    "@vercel/node": "^5.7.16",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
