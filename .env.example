# Set ONE of these. Anthropic preferred (default model: claude-sonnet-4-5).
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: override default model per provider.
# WAYPOINT_MODEL=claude-sonnet-4-5
# WAYPOINT_MODEL=gpt-5.4-mini

# Optional: bridge HTTP port (default 8787).
# PORT=8787
